[MITM]
hostname = %APPEND% 112.53.55.225, 113.46.225.*, 116.85.*, 120.241.142.*, 120.241.143.*, 123.207.209.*, 139.199.240.84, 162.14.157.*, api.live.bilibili.com, api.mcd.cn, api.udache.com, apis.alenable.com, app.bilibili.com, as.xiaojukeji.com, cdb.meituan.com, ccmsupport-sz.tenpay.com, common.diditaxi.com.cn, conf.diditaxi.com.cn, ct.xiaojukeji.com, dynamicad.kfc.com.cn, ecard.shenzhentong.com, edith.xiaohongshu.com, gab.122.gov.cn, lion.didialift.com, m.ctrip.com, ma-adx.ctrip.com, mbd.baidu.com, mp.weixin.qq.com, orders.kfc.com.cn, rec.xiaohongshu.com, res.kfc.com.cn, res.xiaojukeji.com, s.jiediankeji.com, www.itdog.cn
